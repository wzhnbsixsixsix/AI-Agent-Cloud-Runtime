# ------------ LLM Provider ------------
# 取值: openai | mock
LLM_PROVIDER=openai
# OpenAI 兼容 API（可填 OpenAI / DeepSeek / 通义 / Moonshot 等的 base url）
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=60

# ------------ Redis ------------
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# ------------ Endpoints ------------
GATEWAY_GRPC_ADDR=:8080
GATEWAY_ACP_ADDR=:8090
GATEWAY_ACP_CACHE_TTL=1h
GATEWAY_RUN_TIMEOUT=10m
SCHEDULER_GRPC_ADDR=:8081
SCHEDULER_HTTP_ADDR=:8082

# 客户端连接 gateway 时使用（agentctl / bench）
GATEWAY_DIAL_ADDR=localhost:8080
GATEWAY_ACP_DIAL_ADDR=localhost:8090
SCHEDULER_DIAL_ADDR=scheduler:8081

# agentctl 默认协议：grpc | acp
AGENTCTL_PROTO=grpc

# ------------ Worker ------------
WORKER_CONCURRENCY=4
WORKER_CONSUMER_GROUP=workers
WORKER_HEARTBEAT_SECONDS=5
WORKER_MAX_RETRY=3

# ------------ Logging ------------
LOG_LEVEL=info
LOG_FORMAT=json
