# ------------ LLM Provider ------------
# 取值: openai | mock
LLM_PROVIDER=openai
# OpenAI 兼容 API（可填 OpenAI / DeepSeek / 通义 / Moonshot 等的 base url）
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=60

# ------------ Redis ------------
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# ------------ Endpoints ------------
GATEWAY_GRPC_ADDR=:8080
GATEWAY_ACP_ADDR=:8090
GATEWAY_ACP_CACHE_TTL=1h
GATEWAY_RUN_TIMEOUT=10m
GATEWAY_TOOL_CALL_TIMEOUT=60s
SCHEDULER_GRPC_ADDR=:8081
SCHEDULER_HTTP_ADDR=:8082

# 客户端连接 gateway 时使用（agentctl / bench）
GATEWAY_DIAL_ADDR=localhost:8080
GATEWAY_ACP_DIAL_ADDR=localhost:8090
SCHEDULER_DIAL_ADDR=scheduler:8081

# agentctl 默认协议：grpc | acp
AGENTCTL_PROTO=grpc

# ------------ Worker ------------
WORKER_CONCURRENCY=4
WORKER_CONSUMER_GROUP=workers
WORKER_HEARTBEAT_SECONDS=5
WORKER_MAX_RETRY=3

# ------------ W3: Sandbox + Tool ------------
# 取值: docker | memory | disabled
#   docker   生产；需要在 worker 容器里挂 /var/run/docker.sock
#   memory   单测/无 docker 环境；不做容器隔离，仅做工程联调
#   disabled 完全关掉 tool consumer
SANDBOX_DRIVER=docker
SANDBOX_IMAGE=alpine:3.19
SANDBOX_POOL_SIZE=4
# 容器内挂载点（worker 进程角度看到的路径）；docker driver 要求这个目录
# 在宿主与 worker 容器中是同一路径，详见 deploy/docker-compose.yml。
SANDBOX_WORKSPACE_ROOT=/tmp/agentforge
# 仅 docker driver 用：宿主机上 SANDBOX_WORKSPACE_ROOT 实际指向的目录。
# Linux 默认与 ROOT 同；Windows + Docker Desktop 也建议保留 /tmp/agentforge。
SANDBOX_WORKSPACE_HOST=/tmp/agentforge
SANDBOX_MEMORY_MB=256
SANDBOX_CPU_QUOTA_US=50000
SANDBOX_PIDS_LIMIT=256
SANDBOX_EXEC_HARD=60s
SANDBOX_ACQUIRE_TIMEOUT=30s

# Tool runtime（worker 上的 tool consumer）
TOOL_CONSUMER_GROUP=tool-runtime
TOOL_CONCURRENCY=4
# http_fetch 单次最大读取字节数（超过截断）
TOOL_HTTP_MAX_BYTES=1048576
# http_fetch 允许的 host 白名单（逗号分隔，前缀点表示后缀匹配）；空则禁止 http_fetch。
# 例：example.com,.github.io
TOOL_HTTP_ALLOW_LIST=
# Agent 自动 tool-calling 最大轮数，防止模型无限循环调用工具。
AGENT_TOOL_MAX_STEPS=5

# ------------ Logging ------------
LOG_LEVEL=info
LOG_FORMAT=json
